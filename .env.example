# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

PORT=8080
DB_DRIVER=postgres

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=transactions
DB_SSLMODE=disable

# Swagger UI runs on a separate port — set to "" to disable in production
SWAGGER_PORT=9001
